[app]
title = Python Console
package.name = pythonconsole
package.domain = org.pythonapp
source.dir = .
version = 1.0.0
version.code = 1
requirements = python3,kivy
orientation = portrait
fullscreen = 0
android.api = 30
android.sdk = 30
android.ndk = 23b
android.allow_backup = True
android.permissions = WRITE_EXTERNAL_STORAGE
android.debug = True

[buildozer]
log_level = 2
warn_on_root = 1
