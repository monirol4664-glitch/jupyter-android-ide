<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="aperture4.MainPage"
             BackgroundColor="#1a1a2e"
             Title="Aperture4">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <Label Grid.Row="0" 
               Text="🔷 Aperture4"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#eeeeee"
               HorizontalOptions="Center"
               Margin="0,20,0,10"/>

        <ScrollView Grid.Row="1" 
                    BackgroundColor="#0f0f1a"
                    Margin="10">
            <StackLayout x:Name="OutputStack" 
                         Spacing="10"
                         Padding="10"/>
        </ScrollView>

        <Grid Grid.Row="2" 
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              ColumnDefinitions="*,*,*,*,*"
              Margin="10"
              RowSpacing="8"
              ColumnSpacing="8">

            <Button Text="sin" Grid.Row="0" Grid.Column="0" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#4CAF50" FontSize="16"/>
            <Button Text="cos" Grid.Row="0" Grid.Column="1" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#4CAF50" FontSize="16"/>
            <Button Text="tan" Grid.Row="0" Grid.Column="2" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#4CAF50" FontSize="16"/>
            <Button Text="√" Grid.Row="0" Grid.Column="3" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#4CAF50" FontSize="16"/>
            <Button Text="C" Grid.Row="0" Grid.Column="4" Clicked="OnClearClicked" BackgroundColor="#4e2a2a" TextColor="#f44336" FontSize="16"/>

            <Button Text="7" Grid.Row="1" Grid.Column="0" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="8" Grid.Row="1" Grid.Column="1" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="9" Grid.Row="1" Grid.Column="2" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="÷" Grid.Row="1" Grid.Column="3" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>
            <Button Text="^" Grid.Row="1" Grid.Column="4" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>

            <Button Text="4" Grid.Row="2" Grid.Column="0" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="5" Grid.Row="2" Grid.Column="1" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="6" Grid.Row="2" Grid.Column="2" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="×" Grid.Row="2" Grid.Column="3" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>
            <Button Text="(" Grid.Row="2" Grid.Column="4" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>

            <Button Text="1" Grid.Row="3" Grid.Column="0" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="2" Grid.Row="3" Grid.Column="1" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="3" Grid.Row="3" Grid.Column="2" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="−" Grid.Row="3" Grid.Column="3" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>
            <Button Text=")" Grid.Row="3" Grid.Column="4" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>

            <Button Text="0" Grid.Row="4" Grid.Column="0" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="." Grid.Row="4" Grid.Column="1" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#eeeeee" FontSize="20"/>
            <Button Text="π" Grid.Row="4" Grid.Column="2" Clicked="OnButtonClicked" BackgroundColor="#2a2a3e" TextColor="#4CAF50" FontSize="16"/>
            <Button Text="+" Grid.Row="4" Grid.Column="3" Clicked="OnButtonClicked" BackgroundColor="#3a2a4e" TextColor="#ff9800" FontSize="20"/>
            <Button Text="=" Grid.Row="4" Grid.Column="4" Clicked="OnEvaluateClicked" BackgroundColor="#2a6e3a" TextColor="#ffffff" FontSize="24" FontAttributes="Bold"/>
        </Grid>

        <Entry Grid.Row="3"
               x:Name="InputEntry"
               Placeholder="Enter expression..."
               PlaceholderColor="#666666"
               TextColor="#eeeeee"
               BackgroundColor="#0f0f1a"
               FontSize="18"
               Margin="10"
               ReturnType="Done"
               Completed="OnEvaluateClicked"/>
    </Grid>
</ContentPage>
